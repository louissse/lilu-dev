---
import Layout from "../layouts/Layout.astro";
import Button from "../components/ui/Button.astro";
import ButtonLink from "../components/ui/ButtonLink.astro";
import { ArrowUpRight } from "@lucide/astro";
import { MoveRight } from "@lucide/astro";
import DiagonalDivider from "../components/ui/DiagonalDivider.astro";

import { Image } from "astro:assets";
import HeroImage from "../images/hero-image.jpg";
import ProfileImage from "../images/profile.png";
import { getCollection } from "astro:content";

// Get the first two projects
const allProjects = await getCollection("projects");
const sortedProjects = allProjects.sort((a, b) => a.data.order - b.data.order);
const featuredProjects = sortedProjects.slice(0, 2);
---

<Layout bgClass="bg-orange-50">
  <section id="hero" class="pt-12 pb-8 md:pt-22 md:pb-16">
    <div class="container">
      <h2 class="mb-8">Hi, there! I'm Louise,</h2>
      <p
        class="mb-8 text-4xl/12 font-semibold md:text-4xl/12 lg:text-5xl/16 xl:text-6xl/18"
      >
        I build frontend applications that are useful, understandable, and
        genuinely friendly to people.
      </p>
      <div class="mb-10 flex flex-wrap gap-4 md:mb-22">
        <Button text="View projects" href="#projects" />
        <Button
          text="Contact me"
          variant="outline"
          href="mailto:louise@liludigital.dk"
        />
      </div>

      <div class="flex justify-center">
        <Image
          src={HeroImage}
          alt="Image of Louise waving at the camera, smiling, with a blurred background of an office"
          class="rounded-lg"
          width={600}
          height={400}
          format="webp"
          loading="eager"
        />
      </div>
      <DiagonalDivider class="mt-16" />
    </div>
  </section>
  <section id="projects" class="py-8 md:py-16">
    <div class="container">
      <h2 class="mb-8">Projects</h2>
      <p class="mb-8 text-xl">
        About two years ago, I decided to return to hands-on frontend
        development after several years in product and leadership roles. I
        missed the problem-solving and the craft. These projects, both client
        work and personal projects, are some of what I've built since.
      </p>

      <div class="mb-8 grid gap-8 md:grid-cols-2">
        {
          featuredProjects.map((project) => {
            return (
              <div>
                {project.data.image && (
                  <div class="mb-6 aspect-[4/3] w-full">
                    <Image
                      src={project.data.image.src}
                      alt={project.data.image.alt}
                      width={600}
                      height={450}
                      format="webp"
                      loading="lazy"
                      class="h-full w-full rounded-xl object-cover"
                      loading="lazy"
                    />
                  </div>
                )}
                <div class="mb-1 flex flex-wrap gap-4">
                  {project.data.tags.map((tag: string) => (
                    <span class="text-lg font-medium text-red-600">{tag}</span>
                  ))}
                </div>
                <div class="">
                  <h3 class="mb-2 text-2xl font-semibold">
                    <a href={`/projects/${project.id}/`}>
                      {project.data.title}
                    </a>
                  </h3>
                </div>
              </div>
            );
          })
        }
      </div>
      <ButtonLink href="/projects" text="See all projects" variant="secondary">
        <MoveRight class="h-5 w-5" />
      </ButtonLink>
      <DiagonalDivider class="mt-16" />
    </div>
  </section>
  <section id="about" class="py-8 md:py-16">
    <div class="container">
      <h2 class="mb-8">About me</h2>
      <div class="flex flex-col justify-between gap-8 lg:flex-row-reverse">
        <Image
          src={ProfileImage}
          alt="Image of Louise with a red background, smiling and looking at the camera"
          class="mx-auto w-full max-w-sm self-start rounded-xl object-cover lg:mx-0 lg:w-[300px]"
          width={400}
          format="webp"
          loading="lazy"
        />
        <div>
          <p class="mb-6 text-xl">
            I'm a frontend developer building with Astro, React, and TypeScript.
          </p>
          <p class="mb-6 text-xl">
            After starting my career as a developer, I spent several years in
            product and team leadership roles. I'm now back to what I enjoy
            most: building things in code.
          </p>
          <p class="mb-6 text-xl">
            My background is in physics and education, and I care about creating
            technology that's useful, understandable, and genuinely friendly to
            people.
          </p>
          <p class="mb-8 text-xl">
            I'm looking to join a product-focused team where thoughtful
            engineering, collaboration, and continuous learning are valued.
          </p>

          <ButtonLink
            href="/assets/CV-louise-hopfner-dansk.pdf"
            text="Get my resume"
            variant="text"
            external
          >
            <ArrowUpRight class="h-6 w-6" />
          </ButtonLink>
        </div>
      </div>
    </div>
  </section>
</Layout>
