---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
import { getCollection } from "astro:content";

const allProjects = await getCollection("projects");
const sortedProjects = allProjects.sort((a, b) => a.data.order - b.data.order);
---

<Layout
  title="Projects — Frontend Development | Louise Høpfner"
  description="A selection of projects showing how I build web applications, structure frontend systems, and approach product development."
  bgClass="bg-orange-50"
>
  <section class="py-22">
    <div class="container">
      <div class="mb-8 grid gap-8 md:grid-cols-2">
        {
          sortedProjects.map((project) => {
            return (
              <div>
                {project.data.image && (
                  <div class="mb-6 aspect-[4/3] w-full">
                    <Image
                      src={project.data.image.src}
                      alt={project.data.image.alt}
                      width={600}
                      height={450}
                      format="webp"
                      loading="lazy"
                      class="h-full w-full rounded-xl object-cover"
                      loading="lazy"
                    />
                  </div>
                )}
                <div class="mb-1 flex flex-wrap gap-4">
                  {project.data.tags.map((tag: string) => (
                    <span class="text-lg font-medium text-red-600">{tag}</span>
                  ))}
                </div>
                <div class="">
                  <h3 class="mb-2 text-2xl font-semibold">
                    <a href={`/projects/${project.id}/`}>
                      {project.data.title}
                    </a>
                  </h3>
                </div>
              </div>
            );
          })
        }
      </div>
    </div>
  </section></Layout
>
