---
import Layout from "./Layout.astro";
import { Image } from "astro:assets";

export interface Props {
  frontmatter: {
    title: string;
    subtitle: string;
    image?: {
      url: string;
      alt: string;
    };
    tags: string[];
    live?: string;
    github?: string;
  };
}

const { frontmatter } = Astro.props;
---

<Layout title={frontmatter.title}>
  <article class="py-22">
    <div class="container max-w-4xl">
      <!-- Project Header -->
      <div class="mb-12">
        <h1 class="text-4xl md:text-5xl font-bold mb-4">
          {frontmatter.title}
        </h1>
        <p class="text-xl text-gray-600 mb-6">
          {frontmatter.subtitle}
        </p>

        <!-- Project Image -->
        {
          frontmatter.image && (
            <div class="mb-8">
              <Image
                src={frontmatter.image.url}
                alt={frontmatter.image.alt}
                width={800}
                height={450}
                class="w-full rounded-lg shadow-lg"
              />
            </div>
          )
        }

        <!-- Tags -->
        <div class="flex flex-wrap gap-2 mb-6">
          {
            frontmatter.tags.map((tag: string) => (
              <span class="bg-orange-100 text-orange-800 px-3 py-1 rounded-full text-sm font-medium">
                {tag}
              </span>
            ))
          }
        </div>

        <!-- Action Buttons -->
        <div class="flex gap-4 mb-8">
          {
            frontmatter.live && (
              <a
                href={frontmatter.live}
                target="_blank"
                rel="noopener noreferrer"
                class="bg-orange-500 text-white px-6 py-3 rounded-lg hover:bg-orange-600 transition-colors font-medium"
              >
                View Live Site
              </a>
            )
          }
          {
            frontmatter.github && (
              <a
                href={frontmatter.github}
                target="_blank"
                rel="noopener noreferrer"
                class="border-2 border-orange-500 text-orange-500 px-6 py-3 rounded-lg hover:bg-orange-50 transition-colors font-medium"
              >
                View Source Code
              </a>
            )
          }
        </div>
      </div>

      <!-- Project Content -->
      <div class="prose prose-lg max-w-none">
        <slot />
      </div>

      <!-- Back to Projects -->
      <div class="mt-12 pt-8 border-t">
        <a
          href="/#projects"
          class="inline-flex items-center text-orange-500 hover:text-orange-600 transition-colors"
        >
          ← Back to all projects
        </a>
      </div>
    </div>
  </article>
</Layout>
