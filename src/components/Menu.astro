---
// Menu component for responsive navigation
import GithubIcon from "./icons/GithubIcon.astro";
import BlueskyIcon from "./icons/BlueskyIcon.astro";
import LinkedInIcon from "./icons/LinkedInIcon.astro";
import ButtonLink from "./ui/ButtonLink.astro";
import { ArrowUpRight } from "@lucide/astro";
import { AtSign } from "@lucide/astro";
---

<!-- Mobile menu button (visible only on mobile) -->
<button
  id="mobile-menu-button"
  class="absolute top-4 right-4 z-[60] p-3 transition-colors lg:hidden"
  aria-label="Open menu"
>
  <!-- Two-line menu icon (default state) -->
  <svg
    id="menu-icon"
    class="h-6 w-6 stroke-blue-900"
    fill="none"
    viewBox="0 0 24 24"
    stroke-width="2.5"
  >
    <path stroke-linecap="round" stroke-linejoin="round" d="M4 8h16M4 16h16"
    ></path>
  </svg>

  <!-- X icon (hidden by default) -->
  <svg
    id="close-icon"
    class="hidden h-6 w-6 stroke-blue-900"
    fill="none"
    viewBox="0 0 24 24"
    stroke-width="2.5"
  >
    <path
      stroke-linecap="round"
      stroke-linejoin="round"
      d="M6 18L18 6M6 6l12 12"></path>
  </svg>
</button>

<!-- Mobile menu panel (slides in from bottom) -->
<div
  id="mobile-menu-panel"
  class="fixed top-0 right-0 left-0 z-50 h-full w-full translate-y-full transform bg-orange-50 transition-transform duration-300 ease-in-out lg:hidden"
>
  <!-- Mobile menu content -->
  <nav class="px-8 pt-20">
    <div class="mb-8">
      <h1 class="text-3xl font-semibold text-gray-950 underline-offset-4">
        <a class="no-underline hover:underline" href="/">lilu.dev</a>
      </h1>
    </div>

    <ul class="">
      <li>
        <a
          href="/"
          class="block rounded-lg py-2 text-xl font-medium text-gray-950 no-underline underline-offset-4 transition-colors hover:text-blue-700 hover:underline"
          >Home</a
        >
      </li>

      <li>
        <a
          href="/projects"
          class="block rounded-lg py-2 text-xl font-medium text-gray-950 no-underline underline-offset-4 transition-colors hover:text-blue-700 hover:underline"
          >Projects</a
        >
      </li>
      <li>
        <a
          href="/notes"
          class="block rounded-lg py-2 text-xl font-medium text-gray-950 no-underline underline-offset-4 transition-colors hover:text-blue-700 hover:underline"
          >Notes</a
        >
      </li>
    </ul>
    <ul class="pt-8">
      <li class="py-2">
        <ButtonLink
          href="/assets/CV-louise-hopfner-dansk.pdf"
          variant="text"
          text="Resume"
          external><ArrowUpRight class="h-6 w-6" /></ButtonLink
        >
      </li>
      <li class="py-2">
        <ButtonLink
          href="mailto:louise@liludigital.dk"
          variant="text"
          text="Contact"
          external><AtSign class="h-6 w-6" /></ButtonLink
        >
      </li>
    </ul>

    <!-- Social media links (mobile) -->
    <div class="flex items-center gap-6 py-8">
      <a
        href="https://github.com/louissse"
        target="_blank"
        rel="noopener noreferrer"
      >
        <GithubIcon class="h-5 w-5 text-gray-950 hover:text-blue-800" />
      </a>
      <a
        href="https://bsky.app/profile/lilu.dev"
        target="_blank"
        rel="noopener noreferrer"
      >
        <BlueskyIcon class="h-5 w-5 text-gray-950 hover:text-blue-800" />
      </a>
      <a
        href="https://www.linkedin.com/in/louisehopfner/"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="LinkedIn profile"
      >
        <LinkedInIcon
          aria-hidden="true"
          class="h-7 w-7 text-gray-950 hover:text-blue-800"
        />
      </a>
    </div>
  </nav>
</div>

<!-- Desktop sidebar (visible only on desktop) -->
<aside class="fixed top-0 left-0 z-30 hidden h-full w-72 pt-22 pl-16 lg:block">
  <!-- Sidebar header -->
  <div class="">
    <h1 class="text-3xl font-semibold text-gray-950 underline-offset-4">
      <a class="no-underline hover:underline" href="/">lilu.dev</a>
    </h1>
  </div>

  <!-- Sidebar navigation -->
  <nav class="pt-42">
    <ul class="">
      <li>
        <a
          href="/"
          class="block py-2 text-xl font-medium no-underline underline-offset-4 transition-colors hover:underline"
          >Home</a
        >
      </li>

      <li>
        <a
          href="/projects"
          class="block py-2 text-xl font-medium no-underline underline-offset-4 transition-colors hover:underline"
          >Projects</a
        >
      </li>
      <li>
        <a
          href="/notes"
          class="block py-2 text-xl font-medium no-underline underline-offset-4 transition-colors hover:underline"
          >Notes</a
        >
      </li>
    </ul>
    <ul class="pt-8">
      <li class="py-2">
        <ButtonLink
          href="/assets/CV-louise-hopfner-dansk.pdf"
          variant="text"
          text="Resume"
          external><ArrowUpRight class="h-6 w-6" /></ButtonLink
        >
      </li>
      <li class="py-2">
        <ButtonLink
          href="mailto:louise@liludigital.dk"
          variant="text"
          text="Contact"
          external><AtSign class="h-6 w-6" /></ButtonLink
        >
      </li>
    </ul>
  </nav>
  <div class="absolute bottom-0 flex w-full items-center gap-6 py-16">
    <a
      href="https://github.com/louissse"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="GitHub profile"
    >
      <GithubIcon
        aria-hidden="true"
        class="h-5 w-5 text-gray-950 hover:text-blue-800"
      />
    </a>
    <a
      href="https://bsky.app/profile/lilu.dev"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Bluesky profile"
    >
      <BlueskyIcon
        aria-hidden="true"
        class="h-5 w-5 text-gray-950 hover:text-blue-800"
      />
    </a>
    <a
      href="https://www.linkedin.com/in/louisehopfner/"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="LinkedIn profile"
    >
      <LinkedInIcon
        aria-hidden="true"
        class="h-7 w-7 text-gray-950 hover:text-blue-800"
      />
    </a>
  </div>
</aside>

<script>
  // Mobile menu functionality
  const mobileMenuButton = document.getElementById("mobile-menu-button");
  const mobileMenuPanel = document.getElementById("mobile-menu-panel");
  const menuIcon = document.getElementById("menu-icon");
  const closeIcon = document.getElementById("close-icon");

  let isMenuOpen = false;

  function openMobileMenu() {
    mobileMenuPanel?.classList.remove("translate-y-full");
    mobileMenuPanel?.classList.add("translate-y-0");
    isMenuOpen = true;

    // Toggle icons
    menuIcon?.classList.add("hidden");
    closeIcon?.classList.remove("hidden");
  }

  function closeMobileMenu() {
    mobileMenuPanel?.classList.add("translate-y-full");
    mobileMenuPanel?.classList.remove("translate-y-0");
    isMenuOpen = false;

    // Toggle icons back
    menuIcon?.classList.remove("hidden");
    closeIcon?.classList.add("hidden");
  }

  function toggleMenu() {
    if (isMenuOpen) {
      closeMobileMenu();
    } else {
      openMobileMenu();
    }
  }

  // Event listeners
  mobileMenuButton?.addEventListener("click", toggleMenu);

  // Close menu on escape key
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") {
      closeMobileMenu();
    }
  });

  // Close mobile menu when clicking on nav links
  const mobileNavLinks = document.querySelectorAll("#mobile-menu-panel a");
  mobileNavLinks.forEach((link) => {
    link.addEventListener("click", closeMobileMenu);
  });

  // Close menu when clicking outside
  document.addEventListener("click", (e) => {
    if (
      isMenuOpen &&
      !mobileMenuPanel?.contains(e.target as Node) &&
      !mobileMenuButton?.contains(e.target as Node)
    ) {
      closeMobileMenu();
    }
  });
</script>
