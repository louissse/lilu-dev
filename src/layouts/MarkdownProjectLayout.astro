---
import ButtonLink from "../components/ui/ButtonLink.astro";
import DiagonalDivider from "../components/ui/DiagonalDivider.astro";
import Layout from "./Layout.astro";
import { Image } from "astro:assets";
import { ArrowUpRight } from "@lucide/astro";
import { MoveLeft } from "@lucide/astro";
import GithubIcon from "../components/icons/GithubIcon.astro";

export interface Props {
  frontmatter: {
    title: string;
    subtitle: string;
    image?: {
      url: string;
      alt: string;
    };
    tags: string[];
    live?: string;
    github?: string;
  };
}

const { frontmatter } = Astro.props;
---

<Layout title={frontmatter.title} ogImage={frontmatter.image?.url}>
  <article class="pt-22 pb-16">
    <div class="container max-w-4xl">
      <!-- Project Header -->
      <div class="mb-6">
        <h1 class="mb-4 text-4xl font-bold md:text-4xl/tight">
          {frontmatter.title}
        </h1>
        <p class="mb-6 text-xl text-gray-600">
          {frontmatter.subtitle}
        </p>

        <!-- Project Image -->
        {
          frontmatter.image && (
            <div class="ratio-4/3 mb-2 flex w-full flex-row gap-4">
              <Image
                src={frontmatter.image.url}
                alt={frontmatter.image.alt}
                width={600}
                height={450}
                class="w-2/3 rounded-lg"
              />
              <div class="mb-8 flex flex-col">
                {frontmatter.tags.map((tag: string) => (
                  <span class="text-lg font-medium text-red-600">{tag}</span>
                ))}
              </div>
            </div>
          )
        }

        <!-- Tags -->

        <!-- Action Buttons -->
        <div class="mb-8 flex gap-8">
          {
            frontmatter.live && (
              <ButtonLink
                href={frontmatter.live}
                target="_blank"
                text="View Live Project"
                variant="text"
                rel="noopener noreferrer"
              >
                <ArrowUpRight class="h-5 w-5" />
              </ButtonLink>
            )
          }
          {
            frontmatter.github && (
              <ButtonLink
                href={frontmatter.github}
                target="_blank"
                text="View Source Code"
                variant="text"
                rel="noopener noreferrer"
              >
                <GithubIcon class="h-5 w-5" />
              </ButtonLink>
            )
          }
        </div>
      </div>

      <!-- Project Content -->
      <div
        class="prose prose-lg font-albert prose-headings:text-gray-950 prose-headings:font-semibold prose-h1:text-4xl prose-h1:mb-6 prose-h1:mt-8 prose-h2:text-3xl prose-h2:mb-4 prose-h2:mt-8 prose-h2:text-blue-900 prose-h3:text-xl prose-h3:mb-3 prose-h3:mt-6 prose-h3:text-blue-800 prose-p:text-gray-950 prose-p:leading-relaxed prose-p:mb-4 prose-a:text-blue-700 prose-a:no-underline prose-a:font-medium prose-a:hover:underline prose-a:hover:text-blue-900 prose-strong:text-gray-950 prose-strong:font-semibold prose-em:text-red-700 prose-em:italic prose-ul:my-4 prose-li:my-1 prose-li:text-gray-950 prose-ol:my-4 prose-ol:text-gray-950 prose-blockquote:border-l-4 prose-blockquote:border-orange-300 prose-blockquote:bg-orange-50 prose-blockquote:p-4 prose-blockquote:my-6 prose-blockquote:text-red-700 prose-blockquote:italic prose-code:text-blue-800 prose-code:bg-orange-100 prose-code:px-2 prose-code:py-1 prose-code:rounded prose-code:font-mono prose-code:text-sm prose-pre:bg-blue-50 prose-pre:border prose-pre:border-blue-200 prose-pre:p-4 prose-pre:rounded-lg mb-6 max-w-none"
      >
        <slot />
      </div>

      <!-- Divider -->
      <DiagonalDivider class="my-16" variant="blue" />

      <!-- Back to Projects -->
      <div class="mt-12 flex items-center gap-4">
        <ButtonLink
          href="/projects"
          variant="secondary"
          text="Back to all projects"
          iconPosition="left"
        >
          <MoveLeft class="h-5 w-5" />
        </ButtonLink>
      </div>
    </div>
  </article>
</Layout>
